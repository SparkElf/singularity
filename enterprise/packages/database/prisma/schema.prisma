/// L4 控制面只保存治理事实与索引，不保存正文、块或 Kernel 历史。
model GovernancePolicy {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String                   @map("organization_id") @db.Uuid
  spaceId                 String                   @map("space_id") @db.Uuid
  verificationIntervalDays Int                     @default(180) @map("verification_interval_days")
  verificationGraceDays   Int                     @default(30) @map("verification_grace_days")
  archiveAfterDays        Int                     @default(365) @map("archive_after_days")
  retentionDays           Int                     @default(2555) @map("retention_days")
  defaultClassification   GovernanceClassification @default(internal) @map("default_classification")
  watermarkEnabled        Boolean                 @default(true) @map("watermark_enabled")
  governanceEnabled       Boolean                 @default(false) @map("governance_enabled")
  createdByUserId         String                  @map("created_by_user_id") @db.Uuid
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([organizationId, spaceId], map: "governance_policies_organization_space_key")
  @@index([organizationId, updatedAt], map: "governance_policies_organization_updated_idx")
  @@map("governance_policies")
}

