  createdByUserId     String                 @map("created_by_user_id") @db.Uuid
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  completedAt         DateTime?              @map("completed_at") @db.Timestamptz(3)
  activatedAt         DateTime?              @map("activated_at") @db.Timestamptz(3)
  failureCode         String?                @map("failure_code")
  organization        Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_organization_id_fkey")
  backup              SpaceBackup            @relation(fields: [backupId, organizationId, sourceSpaceId], references: [id, organizationId, sourceSpaceId], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_backup_scope_fkey")
  sourceSpace         Space                  @relation("SpaceRestoreSourceSpace", fields: [sourceSpaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_source_space_id_organization_id_fkey")
  targetSpace         Space?                 @relation("SpaceRestoreTargetSpace", fields: [targetSpaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_target_space_id_organization_id_fkey")
  createdBy           User                   @relation("SpaceRestoreCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_created_by_user_id_fkey")
  createdByMembership OrganizationMembership @relation("SpaceRestoreCreatedByMembership", fields: [organizationId, createdByUserId], references: [organizationId, userId], onDelete: Restrict, onUpdate: Cascade, map: "space_restore_jobs_organization_id_created_by_user_id_fkey")

  @@index([organizationId, sourceSpaceId, createdAt], map: "space_restore_jobs_source_created_idx")
  @@index([workerJobId, workerAttempt], map: "space_restore_jobs_worker_claim_idx")
  @@map("space_restore_jobs")
}

