generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

enum OrganizationStatus {
  active
  disabled

  @@map("organization_status")
}

enum OrganizationRole {
  owner
  admin
  member

  @@map("organization_role")
}

enum MembershipStatus {
  active
  inactive

  @@map("membership_status")
}

enum UserGroupStatus {
  active
  disabled

  @@map("user_group_status")
}

enum SpaceStatus {
  active
  archived
  disabled

  @@map("space_status")
}

enum OidcProviderStatus {
  active
  disabled

  @@map("oidc_provider_status")
}

enum SpaceRole {
  admin
  editor
  viewer

  @@map("space_role")
}

enum DocumentAccessMode {
  inherit
  restricted

  @@map("document_access_mode")
}

enum DocumentAccessRole {
  viewer
  commenter
  editor

  @@map("document_access_role")
}

enum DocumentAccessGrantKind {
  user
  group

  @@map("document_access_grant_kind")
}

enum CommentThreadStatus {
  open
  resolved
  deleted

  @@map("comment_thread_status")
}

enum NotificationKind {
  mention
  comment_reply       @map("comment-reply")
  comment_resolved    @map("comment-resolved")
  permission_changed  @map("permission-changed")
  history_restored    @map("history-restored")

  @@map("notification_kind")
}

enum KernelInstanceStatus {
  starting
  ready
  unavailable

  @@map("kernel_instance_status")
}

enum WorkerJobKind {
  archive_audit  @map("archive-audit")
  backup_space   @map("backup-space")
  reconcile_content_audit @map("reconcile-content-audit")
  restore_space  @map("restore-space")
  sample_kernel  @map("sample-kernel")
  governance_task @map("governance-task")

  @@map("worker_job_kind")
}

enum WorkerJobStatus {
  queued
  running
  succeeded
  failed

  @@map("worker_job_status")
}

enum SpaceBackupStatus {
  queued
  running
  succeeded
  failed

  @@map("space_backup_status")
}

enum SpaceRestoreStatus {
  queued
  restoring
  ready_for_activation @map("ready-for-activation")
  activated
  failed

  @@map("space_restore_status")
}

enum AuditAction {
  authentication_login @map("authentication.login")
  content_delete       @map("content.delete")
  content_edit         @map("content.edit")
  content_export       @map("content.export")
  permission_change    @map("permission.change")
  share_create         @map("share.create")
  share_password_change @map("share.password-change")
  share_revoke         @map("share.revoke")
  backup_create        @map("backup.create")
  restore_create       @map("restore.create")
  restore_activate     @map("restore.activate")
  comment_create       @map("comment.create")
  comment_reply        @map("comment.reply")
  comment_edit         @map("comment.edit")
  comment_resolve      @map("comment.resolve")
  comment_reopen       @map("comment.reopen")
  comment_delete       @map("comment.delete")
  history_view         @map("history.view")
  history_restore      @map("history.restore")
  notification_read    @map("notification.read")
  collaboration_join      @map("collaboration.join")
  collaboration_operation @map("collaboration.operation")
  collaboration_conflict  @map("collaboration.conflict")
  collaboration_resume    @map("collaboration.resume")
  collaboration_revoke    @map("collaboration.revoke")

  @@map("audit_action")
}

enum AuditOutcome {
  denied
  failed
  indeterminate
  succeeded

  @@map("audit_outcome")
}

enum KernelObservationStatus {
  ready
  unavailable

  @@map("kernel_observation_status")
}

enum CollaborationFeatureMode {
  standard
  restricted_encrypted @map("restricted-encrypted")

  @@map("collaboration_feature_mode")
}

enum CollaborationSessionStatus {
  connecting
  ready
  reconnecting
  conflict
  revoked
  closed

  @@map("collaboration_session_status")
}

enum GovernanceLifecycleStatus {
  draft
  in_review
  approved
  published
  archived
  rejected

  @@map("governance_lifecycle_status")
}

enum GovernanceVerificationStatus {
  verified
  needs_review
  expired

  @@map("governance_verification_status")
}

enum GovernanceClassification {
  public
  internal
  confidential
  restricted

  @@map("governance_classification")
}

enum GovernanceApprovalStatus {
  pending
  approved
  rejected

  @@map("governance_approval_status")
}

enum GovernanceTaskKind {
  verify
  archive
  retain
  export_watermark

  @@map("governance_task_kind")
}

enum GovernanceTaskStatus {
  queued
  running
  succeeded
  failed
  cancelled

  @@map("governance_task_status")
}

enum GovernanceTemplateStatus {
  draft
  published
  archived

  @@map("governance_template_status")
}

enum EnterpriseIdentityProviderStatus {
  active
  disabled

  @@map("enterprise_identity_provider_status")
}

enum ScimExternalIdentityKind {
  user
  group

  @@map("scim_external_identity_kind")
}

enum EmbeddedObjectKind {
  drawio
  excalidraw

  @@map("embedded_object_kind")
}

enum EmbeddedObjectStatus {
  active
  unavailable
  deleted

  @@map("embedded_object_status")
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loginIdentifier         String                   @unique(map: "users_login_identifier_key") @map("login_identifier")
  passwordDigest          String?                  @map("password_digest")
  status                  UserStatus
  authSessions            AuthSession[]
  acceptedInvitations     OrganizationInvitation[] @relation("AcceptedInvitationUser")
  createdInvitations      OrganizationInvitation[] @relation("CreatedInvitationUser")
  groupMemberships        UserGroupMembership[]    @relation("UserGroupMembershipUser")
  oidcIdentities          OidcIdentity[]
  organizationMemberships OrganizationMembership[]
  auditEvents              AuditEvent[]              @relation("AuditEventActorUser")
  contentAuditIntents      ContentAuditIntent[]       @relation("ContentAuditIntentActorUser")
  createdDocumentShares    DocumentShare[]           @relation("DocumentShareCreatedByUser")
  createdSpaceBackups      SpaceBackup[]             @relation("SpaceBackupCreatedByUser")
  createdSpaceRestores     SpaceRestoreJob[]         @relation("SpaceRestoreCreatedByUser")
  documentAccessGrants     DocumentAccessGrant[]     @relation("DocumentAccessGrantUser")
  createdCommentThreads    CommentThread[]           @relation("CommentThreadCreatedByUser")
  commentEntries           CommentEntry[]            @relation("CommentEntryAuthorUser")
  receivedNotifications    Notification[]            @relation("NotificationRecipientUser")
  actedNotifications       Notification[]            @relation("NotificationActorUser")
  collaborationSessions    CollaborationSession[]

  @@map("users")
}

model SystemInstallation {
  id            Int      @id
  initializedAt DateTime @map("initialized_at") @db.Timestamptz(3)

  @@map("system_installations")
}

model AuthSession {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenDigest       String    @unique(map: "auth_sessions_token_digest_key") @map("token_digest")
  csrfDigest        String    @map("csrf_digest")
  absoluteExpiresAt DateTime  @map("absolute_expires_at") @db.Timestamptz(3)
  idleExpiresAt     DateTime  @map("idle_expires_at") @db.Timestamptz(3)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(3)
  user              User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "auth_sessions_user_id_fkey")
  collaborationSessions CollaborationSession[]

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@map("auth_sessions")
}

model Organization {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  status        OrganizationStatus
  invitations   OrganizationInvitation[]
  memberships   OrganizationMembership[]
  oidcProviders OidcProvider[]
  spaces        Space[]
  userGroups    UserGroup[]
  auditArchives AuditArchive[]
  auditEvents   AuditEvent[]
  contentAuditIntents ContentAuditIntent[]
  auditSequence OrganizationAuditSequence?
  documentShares DocumentShare[]
  documentAccessPolicies DocumentAccessPolicy[]
  commentThreads CommentThread[]
  notifications Notification[]
  spaceBackups  SpaceBackup[]
  spaceRestores SpaceRestoreJob[]
  workerJobs    WorkerJob[]
  collaborationFeatures CollaborationFeature[]
  collaborationSessions CollaborationSession[]
  collaborationAuditEvents CollaborationAuditEvent[]

  @@map("organizations")
}

model OrganizationMembership {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  role             OrganizationRole
  status           MembershipStatus
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "organization_memberships_organization_id_fkey")
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "organization_memberships_user_id_fkey")
  groupMemberships UserGroupMembership[] @relation("UserGroupMembershipOrganizationMembership")
  oidcIdentities    OidcIdentity[]
  spaceMemberships SpaceMembership[] @relation("SpaceMembershipOrganizationMembership")
  auditEvents       AuditEvent[]      @relation("AuditEventActorMembership")
  contentAuditIntents ContentAuditIntent[] @relation("ContentAuditIntentActorMembership")
  createdDocumentShares DocumentShare[] @relation("DocumentShareCreatedByMembership")
  createdSpaceBackups SpaceBackup[]   @relation("SpaceBackupCreatedByMembership")
  createdSpaceRestores SpaceRestoreJob[] @relation("SpaceRestoreCreatedByMembership")
  personalSpaces PersonalSpace[] @relation("PersonalSpaceOwnerMembership")

  @@unique([organizationId, userId], map: "organization_memberships_organization_id_user_id_key")
  @@index([userId], map: "organization_memberships_user_id_idx")
  @@map("organization_memberships")
}

model Space {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  name           String
  status         SpaceStatus
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "spaces_organization_id_fkey")
  memberships    SpaceMembership[] @relation("SpaceMembershipSpace")
  groupGrants    SpaceGroupGrant[] @relation("SpaceGroupGrantSpace")
  kernelInstance KernelInstance?
  auditEvents    AuditEvent[]              @relation("AuditEventSpace")
  contentAuditIntents ContentAuditIntent[]  @relation("ContentAuditIntentSpace")
  capacityObservations SpaceCapacityObservation[]
  documentShares DocumentShare[]           @relation("DocumentShareSpace")
  sourceBackups SpaceBackup[]               @relation("SpaceBackupSourceSpace")
  sourceRestores SpaceRestoreJob[]          @relation("SpaceRestoreSourceSpace")
  targetRestores SpaceRestoreJob[]          @relation("SpaceRestoreTargetSpace")
  documentAccessPolicies DocumentAccessPolicy[]
  commentThreads CommentThread[]
  notifications Notification[]
  collaborationFeatures CollaborationFeature[]
  collaborationSessions CollaborationSession[]
  collaborationAuditEvents CollaborationAuditEvent[]

  @@unique([id, organizationId], map: "spaces_id_organization_id_key")
  @@index([organizationId], map: "spaces_organization_id_idx")
  @@map("spaces")
}

model OrganizationInvitation {
  id                 String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String                     @map("organization_id") @db.Uuid
  loginIdentifier    String                     @map("login_identifier")
  role               OrganizationRole
  tokenDigest        String                     @unique(map: "organization_invitations_token_digest_key") @map("token_digest")
  expiresAt          DateTime                   @map("expires_at") @db.Timestamptz(3)
  acceptedAt         DateTime?                  @map("accepted_at") @db.Timestamptz(3)
  revokedAt          DateTime?                  @map("revoked_at") @db.Timestamptz(3)
  invitedByUserId    String                     @map("invited_by_user_id") @db.Uuid
  acceptedByUserId   String?                    @map("accepted_by_user_id") @db.Uuid
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "organization_invitations_organization_id_fkey")
  invitedBy          User                       @relation("CreatedInvitationUser", fields: [invitedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "organization_invitations_invited_by_user_id_fkey")
  acceptedBy         User?                      @relation("AcceptedInvitationUser", fields: [acceptedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "organization_invitations_accepted_by_user_id_fkey")
  oidcAttempts       OidcAuthorizationAttempt[]

  @@unique([id, organizationId], map: "organization_invitations_id_organization_id_key")
  @@index([organizationId, loginIdentifier], map: "organization_invitations_organization_id_login_identifier_idx")
  @@index([expiresAt], map: "organization_invitations_expires_at_idx")
  @@map("organization_invitations")
}

model UserGroup {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  name           String
  status         UserGroupStatus
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "user_groups_organization_id_fkey")
  memberships    UserGroupMembership[] @relation("UserGroupMembershipGroup")
  spaceGrants    SpaceGroupGrant[]     @relation("SpaceGroupGrantGroup")
  documentAccessGrants DocumentAccessGrant[] @relation("DocumentAccessGrantGroup")

  @@unique([id, organizationId], map: "user_groups_id_organization_id_key")
  @@unique([organizationId, name], map: "user_groups_organization_id_name_key")
  @@index([organizationId], map: "user_groups_organization_id_idx")
  @@map("user_groups")
}

model UserGroupMembership {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String                 @map("organization_id") @db.Uuid
  groupId                String                 @map("group_id") @db.Uuid
  userId                 String                 @map("user_id") @db.Uuid
  group                  UserGroup              @relation("UserGroupMembershipGroup", fields: [groupId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "user_group_memberships_group_id_organization_id_fkey")
  user                   User                   @relation("UserGroupMembershipUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "user_group_memberships_user_id_fkey")
  organizationMembership OrganizationMembership @relation("UserGroupMembershipOrganizationMembership", fields: [organizationId, userId], references: [organizationId, userId], onDelete: Restrict, onUpdate: Cascade, map: "user_group_memberships_organization_id_user_id_fkey")

  @@unique([groupId, userId], map: "user_group_memberships_group_id_user_id_key")
  @@index([organizationId, userId], map: "user_group_memberships_organization_id_user_id_idx")
  @@map("user_group_memberships")
}

model SpaceGroupGrant {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  spaceId        String      @map("space_id") @db.Uuid
  groupId        String      @map("group_id") @db.Uuid
  role           SpaceRole
  space          Space       @relation("SpaceGroupGrantSpace", fields: [spaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "space_group_grants_space_id_organization_id_fkey")
  group          UserGroup   @relation("SpaceGroupGrantGroup", fields: [groupId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "space_group_grants_group_id_organization_id_fkey")

  @@unique([spaceId, groupId], map: "space_group_grants_space_id_group_id_key")
  @@index([organizationId, groupId], map: "space_group_grants_organization_id_group_id_idx")
  @@map("space_group_grants")
}

model DocumentAccessPolicy {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  spaceId        String                 @map("space_id") @db.Uuid
  notebookId     String                 @map("notebook_id")
  documentId     String                 @map("document_id")
  mode           DocumentAccessMode
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "document_access_policies_organization_id_fkey")
  space          Space                  @relation(fields: [spaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "document_access_policies_space_id_organization_id_fkey")
  grants         DocumentAccessGrant[]

  @@unique([organizationId, spaceId, notebookId, documentId], map: "document_access_policies_identity_key")
  @@unique([id, organizationId, spaceId, notebookId, documentId], map: "document_access_policies_scope_key")
  @@index([organizationId, spaceId, updatedAt], map: "document_access_policies_space_updated_idx")
  @@map("document_access_policies")
}

model DocumentAccessGrant {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId       String               @map("policy_id") @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  spaceId        String               @map("space_id") @db.Uuid
  notebookId     String               @map("notebook_id")
  documentId     String               @map("document_id")
  kind           DocumentAccessGrantKind
  userId         String?              @map("user_id") @db.Uuid
  groupId        String?              @map("group_id") @db.Uuid
  role           DocumentAccessRole
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  policy         DocumentAccessPolicy @relation(fields: [policyId, organizationId, spaceId, notebookId, documentId], references: [id, organizationId, spaceId, notebookId, documentId], onDelete: Cascade, onUpdate: Cascade, map: "document_access_grants_policy_scope_fkey")
  user           User?                @relation("DocumentAccessGrantUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "document_access_grants_user_id_fkey")
  group          UserGroup?           @relation("DocumentAccessGrantGroup", fields: [groupId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "document_access_grants_group_scope_fkey")

  @@unique([id, organizationId, spaceId, notebookId, documentId], map: "document_access_grants_scope_key")
  @@index([organizationId, spaceId, notebookId, documentId, createdAt], map: "document_access_grants_document_created_idx")
  @@index([organizationId, userId], map: "document_access_grants_user_idx")
  @@index([organizationId, groupId], map: "document_access_grants_group_idx")
  @@map("document_access_grants")
}

model CommentThread {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  spaceId        String              @map("space_id") @db.Uuid
  notebookId     String              @map("notebook_id")
  documentId     String              @map("document_id")
  anchorBlockId  String?             @map("anchor_block_id")
  status         CommentThreadStatus
  createdByUserId String             @map("created_by_user_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  resolvedAt     DateTime?           @map("resolved_at") @db.Timestamptz(3)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "comment_threads_organization_id_fkey")
  space          Space               @relation(fields: [spaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "comment_threads_space_id_organization_id_fkey")
  createdBy      User                @relation("CommentThreadCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "comment_threads_created_by_user_id_fkey")
  entries        CommentEntry[]
  notifications  Notification[]

  @@unique([id, organizationId, spaceId, notebookId, documentId], map: "comment_threads_scope_key")
  @@index([organizationId, spaceId, notebookId, documentId, createdAt, id], map: "comment_threads_document_created_idx")
  @@map("comment_threads")
}

model CommentEntry {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId       String        @map("thread_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  spaceId        String        @map("space_id") @db.Uuid
  notebookId     String        @map("notebook_id")
  documentId     String        @map("document_id")
  authorUserId   String        @map("author_user_id") @db.Uuid
  body           String
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  editedAt       DateTime?     @map("edited_at") @db.Timestamptz(3)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(3)
  thread         CommentThread @relation(fields: [threadId, organizationId, spaceId, notebookId, documentId], references: [id, organizationId, spaceId, notebookId, documentId], onDelete: Cascade, onUpdate: Cascade, map: "comment_entries_thread_scope_fkey")
  author         User          @relation("CommentEntryAuthorUser", fields: [authorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "comment_entries_author_user_id_fkey")

  @@unique([id, organizationId, spaceId, notebookId, documentId], map: "comment_entries_scope_key")
  @@index([organizationId, spaceId, notebookId, documentId, threadId, createdAt, id], map: "comment_entries_thread_created_idx")
  @@map("comment_entries")
}

model Notification {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientUserId String          @map("recipient_user_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  spaceId        String           @map("space_id") @db.Uuid
  notebookId     String           @map("notebook_id")
  documentId     String           @map("document_id")
  kind           NotificationKind
  eventKey       String           @map("event_key")
  actorUserId    String?          @map("actor_user_id") @db.Uuid
  threadId       String?          @map("thread_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  readAt         DateTime?        @map("read_at") @db.Timestamptz(3)
  recipient      User             @relation("NotificationRecipientUser", fields: [recipientUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "notifications_recipient_user_id_fkey")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "notifications_organization_id_fkey")
  space          Space            @relation(fields: [spaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "notifications_space_id_organization_id_fkey")
  actor          User?            @relation("NotificationActorUser", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "notifications_actor_user_id_fkey")
  thread         CommentThread?   @relation(fields: [threadId, organizationId, spaceId, notebookId, documentId], references: [id, organizationId, spaceId, notebookId, documentId], onDelete: Restrict, onUpdate: Cascade, map: "notifications_thread_scope_fkey")

  @@unique([recipientUserId, eventKey], map: "notifications_recipient_event_key")
  @@index([recipientUserId, readAt, createdAt, id], map: "notifications_recipient_read_idx")
  @@index([organizationId, spaceId, notebookId, documentId, createdAt], map: "notifications_document_created_idx")
  @@map("notifications")
}

model CollaborationFeature {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId           String   @map("organization_id") @db.Uuid
  spaceId                  String   @map("space_id") @db.Uuid
  notebookId               String   @map("notebook_id")
  documentId               String   @map("document_id")
  standardEnabled          Boolean  @map("standard_enabled")
  restrictedEncryptedEnabled Boolean @map("restricted_encrypted_enabled")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade, map: "collaboration_features_organization_id_fkey")
  space                    Space @relation(fields: [spaceId, organizationId], references: [id, organizationId], onDelete: Restrict, onUpdate: Cascade, map: "collaboration_features_space_id_organization_id_fkey")

  @@unique([organizationId, spaceId, notebookId, documentId], map: "collaboration_features_identity_key")
  @@index([organizationId, spaceId, updatedAt], map: "collaboration_features_space_updated_idx")
  @@map("collaboration_features")
}

model CollaborationSession {
  id               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String                     @map("organization_id") @db.Uuid
  spaceId          String                     @map("space_id") @db.Uuid
