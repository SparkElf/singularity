{
  "name": "@singularity/database",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing/postgres": {
      "development": {
        "types": "./test/support/postgres.ts",
        "default": "./test/support/postgres.ts"
      }
    }
  },
  "scripts": {
    "build": "pnpm generate && tsc -p tsconfig.build.json",
    "deploy": "prisma migrate deploy --config prisma.config.ts && pnpm run deploy:audit-privileges",
    "deploy:audit-privileges": "psql --no-psqlrc --set=ON_ERROR_STOP=1 --single-transaction --set=singularity_schema=\"$SINGULARITY_DB_SCHEMA\" --set=audit_writer_role=\"$SINGULARITY_AUDIT_WRITER_ROLE\" --set=audit_reader_role=\"$SINGULARITY_AUDIT_READER_ROLE\" \"$DATABASE_URL\" --file deploy/audit-privileges.sql",
    "generate": "prisma generate --config prisma.config.ts",
    "test:integration": "pnpm generate && vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm generate && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@singularity/contracts": "workspace:*",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@singularity/authorization": "workspace:*",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
