{
  "name": "@singularity/web",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "pnpm prepare:protyle-runtime && tsc -p tsconfig.json && vite build",
    "dev": "pnpm prepare:protyle-runtime && vite --host 0.0.0.0",
    "prepare:protyle-runtime": "node scripts/prepare-protyle-runtime.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "test:browser-integration": "playwright test --config playwright.integration.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:space-access": "vitest run src/app/App.test.tsx src/spaces",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.test.json && tsc -p tsconfig.tooling.json"
  },
  "dependencies": {
    "@singularity/contracts": "workspace:*",
    "@singularity/protyle-browser": "workspace:*",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "1.24.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
