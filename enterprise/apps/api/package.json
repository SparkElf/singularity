{
  "name": "@singularity/api",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "access-operations": "node dist/operations/main.js",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:release-certification": "vitest run --config vitest.release.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@node-rs/argon2": "2.0.2",
    "@node-saml/node-saml": "5.1.0",
    "@singularity/authorization": "workspace:*",
    "@singularity/contracts": "workspace:*",
    "@singularity/database": "workspace:*",
    "@singularity/kernel-client": "workspace:*",
    "rate-limiter-flexible": "11.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "ws": "8.21.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/ws": "8.18.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
